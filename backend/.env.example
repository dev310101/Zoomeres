# ── Admin Security (REQUIRED) ─────────────────────────────
# Choose a strong password — min 16 chars, mix of chars/numbers
ADMIN_PASSWORD=MyLocalDevPassword123!

# Random string used to sign JWT tokens
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# How long admin sessions last in seconds (3600 = 1 hour)
ADMIN_SESSION_TIMEOUT=3600

# ── Amazon PA-API (optional, needs 3 sales first) ─────────
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=yourtag-21

# ── Flipkart Affiliate (optional) ────────────────────────
FLIPKART_AFFILIATE_ID=
FLIPKART_API_TOKEN=

# ── Server ────────────────────────────────────────────────
PORT=5000

# ── CORS (set to your Vercel URL in production) ───────────
FRONTEND_URL=https://zoomeres.vercel.app
